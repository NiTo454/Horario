datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Semester {
  id        String    @id @default(uuid())
  name      String
  isActive  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  subjects  Subject[]
}

model Subject {
  id          String         @id @default(uuid())
  name        String
  teacher     String?
  classroom   String?
  color       String         @default("purple") // e.g. "purple", "indigo", "violet", "pink", "fuchsia", "lavender"
  semesterId  String
  semester    Semester       @relation(fields: [semesterId], references: [id], onDelete: Cascade)
  slots       ScheduleSlot[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model ScheduleSlot {
  id        String   @id @default(uuid())
  dayOfWeek Int      // 1 = Lunes, 2 = Martes, 3 = Miércoles, 4 = Jueves, 5 = Viernes, 6 = Sábado, 7 = Domingo
  startTime String   // Formato "HH:MM" (ej. "08:00")
  endTime   String   // Formato "HH:MM" (ej. "10:00")
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
}
